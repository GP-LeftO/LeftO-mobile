{
  "expo": {
    "name": "LeftO",
    "slug": "lefto",
    "scheme": "lefto",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "userInterfaceStyle": "light",
    "updates": {
      "enabled": false
    },
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "LeftO يستخدم التعرف على الكلام للبحث عن العروض القريبة منك.",
        "NSMicrophoneUsageDescription": "LeftO يحتاج إلى الميكروفون لتحويل صوتك إلى نص."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#DE985A"
      },
      "package": "lefto.com",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-av",
      "expo-localization",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "LeftO needs your location to show nearby sellers."
        }
      ],
      "expo-asset",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.lefto.com",
          "enableGooglePay": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#DE985A",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "53fdcedd-7456-48a7-a831-bf5c6fde5a52"
      }
    }
  }
}
